<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/register_volunteering"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutDirection="rtl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:padding="28dp"
                android:paddingBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="קביעת התנדבות"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:fontFamily="@font/galacti"
                    android:shadowColor="#33000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"/>

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFF9C4"
                    android:textSize="16sp"
                    android:fontFamily="@font/rubiklight"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 בחירת מקום התנדבות"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layoutDirection="rtl"
                        android:gravity="center_vertical"
                        android:background="@drawable/edittext_rounded"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:layout_marginStart="12dp"
                            app:tint="#F0D238"/>

                        <AutoCompleteTextView
                            android:id="@+id/actvSearchPlace"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="חפש מקום התנדבות..."
                            android:textColorHint="#AAAAAA"
                            android:textColor="#222222"
                            android:textSize="15sp"
                            android:fontFamily="@font/rubiklight"
                            android:padding="14dp"
                            android:background="@null"
                            android:completionThreshold="1"
                            android:textDirection="rtl"
                            android:layoutDirection="rtl"
                            android:gravity="right|center_vertical"
                            android:inputType="text"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectedPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="@font/rubiklight"
                        android:gravity="center"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlaceImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼️ תמונות המקום"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="12dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/imagesContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="120dp"
                            android:orientation="horizontal"/>

                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlaceSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐 שעות פעילות"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPlaceSchedule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#444444"
                        android:fontFamily="@font/gveretlevin"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 בחירת תאריך ושעות"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnSelectDate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="בחר תאריך"
                        android:textSize="15sp"
                        android:fontFamily="@font/gveretlevin"
                        android:backgroundTint="@color/myyellow"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="16dp"
                        app:cornerRadius="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="שעת התחלה"
                                android:textSize="13sp"
                                android:fontFamily="@font/rubiklight"
                                android:textColor="#666666"
                                android:gravity="center"
                                android:layout_marginBottom="8dp"/>

                            <Button
                                android:id="@+id/btnSelectStartTime"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="בחר שעה"
                                android:backgroundTint="@color/myyellow"
                                android:textSize="13sp"
                                android:fontFamily="@font/gveretlevin"
                                android:textColor="#1A1A2E"
                                app:cornerRadius="12dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="שעת סיום"
                                android:textSize="13sp"
                                android:fontFamily="@font/rubiklight"
                                android:textColor="#666666"
                                android:gravity="center"
                                android:layout_marginBottom="8dp"/>

                            <Button
                                android:id="@+id/btnSelectEndTime"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="בחר שעה"
                                android:backgroundTint="@color/myyellow"
                                android:textSize="13sp"
                                android:fontFamily="@font/gveretlevin"
                                android:textColor="#1A1A2E"
                                app:cornerRadius="12dp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVolunteeringDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:gravity="center"
                        android:padding="12dp"
                        android:visibility="gone"
                        android:background="@drawable/edittext_rounded"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <Button
                        android:id="@+id/btnSubmitVolunteering"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="שלח בקשת התנדבות"
                        android:fontFamily="@font/rubicblack"
                        android:backgroundTint="@color/myyellow"
                        android:textSize="18sp"
                        android:textColor="#1A1A2E"
                        android:enabled="false"
                        app:cornerRadius="16dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/imageOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivFullscreenImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="32dp"/>

        <TextView
            android:id="@+id/btnCloseOverlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="✕"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>