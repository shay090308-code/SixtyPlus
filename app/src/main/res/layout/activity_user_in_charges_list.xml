<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layoutDirection="rtl"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient"
            android:orientation="vertical"
            android:padding="28dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="רשימת אחראים"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:fontFamily="@font/galacti"
                android:shadowColor="#33000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="8"/>

            <TextView
                android:id="@+id/tvuserinchargecount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מספר אחראים כולל: 0"
                android:textColor="#FFF9C4"
                android:textSize="16sp"
                android:fontFamily="@font/rubiklight"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rtvinchargelist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="-24dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>