<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layoutDirection="rtl"
            android:padding="24dp">

            <!-- ברכה + שם -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="בוקר טוב!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/galacti"
                android:textColor="#000000"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:fontFamily="@font/rubiklight"
                android:textColor="#000000"
                android:layout_marginBottom="24dp"/>

            <!-- עיגול פרוגרס -->
            <com.example.sixtyplus.views.CircularProgressView
                android:id="@+id/circularProgress"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"/>

            <!-- טקסט שעות -->
            <TextView
                android:id="@+id/tvHoursText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:fontFamily="@font/rubiklight"
                android:textColor="#000000"
                android:gravity="center"
                android:textAlignment="center"
                android:layout_marginBottom="8dp"/>

            <!-- פרוגרס בר ימים -->
            <ProgressBar
                android:id="@+id/progressBarDays"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="300dp"
                android:layout_height="20dp"
                android:progressDrawable="@drawable/progress_bar_yellow"
                android:max="100"
                android:layout_marginBottom="8dp"/>

            <!-- טקסט ימים שנשארו -->
            <TextView
                android:id="@+id/tvDaysLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:fontFamily="@font/rubiklight"
                android:textColor="#000000"
                android:layout_marginBottom="32dp"/>

            <!-- טבלת 3 הימים הקרובים -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":3 הימים הקרובים"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/gveretlevin"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"/>

            <TableLayout
                android:id="@+id/tableUpcoming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:background="#000000"
                android:layout_marginBottom="32dp">

                <!-- כותרת -->
                <TableRow
                    android:background="#000000">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="תאריך"
                        android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin"
                        android:textColor="#000000"
                        android:background="#FFFFFF"
                        android:padding="8dp"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="שעות"
                        android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin"
                        android:textColor="#000000"
                        android:background="#FFFFFF"
                        android:padding="8dp"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="מקום"
                        android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin"
                        android:textColor="#000000"
                        android:background="#FFFFFF"
                        android:padding="8dp"
                        android:gravity="center"/>
                </TableRow>

            </TableLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>