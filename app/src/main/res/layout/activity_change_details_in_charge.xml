<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/change_details_in_charge"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutDirection="rtl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:padding="28dp"
                android:paddingBottom="40dp">

                <TextView
                    android:id="@+id/changeInChargeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="עדכון פרטים"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:fontFamily="@font/galacti"
                    android:shadowColor="#33000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"/>

                <TextView
                    android:id="@+id/ChangeInChargerDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="עדכן את פרטיך במידת הצורך"
                    android:textColor="#FFF9C4"
                    android:textSize="16sp"
                    android:fontFamily="@font/rubiklight"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 פרטים אישיים"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="תעודת זהות"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/idNumberInChargeChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:editable="false"
                            android:fontFamily="@font/gveretlevin"
                            android:inputType="text"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="שם פרטי ✏️"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/firstNameInChargeChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="שם משפחה ✏️"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/lastNameInChargeChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="מספר טלפון ✏️"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/phoneInChargeChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:inputType="phone"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Spinner
                        android:id="@+id/cityInChargeChange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@drawable/spinner_background"
                        android:spinnerMode="dropdown"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 פרטי מקום ההתנדבות"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="שם מקום ההתנדבות ✏️"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/placeNameChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="כתובת מקום ההתנדבות ✏️"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/placeAdressChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="תיאור על המקום"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/placeDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"
                            android:minLines="3"
                            android:gravity="top|right"
                            android:textColor="#000000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐 שעות פעילות"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="אם ביום מסוים אין אפשרות להתנדב יש להשאיר ריק"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#888888"
                        android:layout_marginBottom="20dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום ראשון" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startSunday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endSunday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום שני" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startMonday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endMonday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום שלישי" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startTuesday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endTuesday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום רביעי" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startWednesday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endWednesday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום חמישי" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startThursday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endThursday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום שישי" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
                        <EditText android:id="@+id/startFriday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endFriday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="יום שבת" android:textSize="15sp" android:textStyle="bold"
                        android:fontFamily="@font/gveretlevin" android:textColor="#1A1A2E"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
                        <EditText android:id="@+id/startSaturday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" עד " android:textColor="#666666" android:layout_marginHorizontal="8dp"/>
                        <EditText android:id="@+id/endSaturday" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="@drawable/edittext_rounded" android:padding="12dp" android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼️ תמונות המקום"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ניתן להעלות עד 6 תמונות"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#888888"
                        android:layout_marginBottom="16dp"/>

                    <GridLayout
                        android:id="@+id/imagesGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:rowCount="2"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnAddImage"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="+ הוסף תמונה"
                        android:fontFamily="@font/gveretlevin"
                        android:backgroundTint="@color/myyellow"
                        android:textColor="#1A1A2E"
                        android:textSize="15sp"
                        app:cornerRadius="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒 שינוי סיסמא"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/rubiklight"
                        android:textColor="#222222"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="סיסמא נוכחית"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/nowPasswordInChargeChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:editable="false"
                            android:fontFamily="@font/gveretlevin"
                            android:padding="8dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="סיסמא חדשה"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/newPasswordInCharge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:inputType="textPassword"
                            android:padding="8dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:hint="אימות סיסמא חדשה"
                        android:textColorHint="#999999"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/myyellow"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/newPasswordInChargeConfirm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gveretlevin"
                            android:inputType="textPassword"
                            android:padding="8dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/saveChangesInChargeBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="@color/myyellow"
                        android:fontFamily="@font/rubicblack"
                        android:text="שמור שינויים"
                        android:textColor="#1A1A2E"
                        android:textSize="18sp"
                        app:cornerRadius="16dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>